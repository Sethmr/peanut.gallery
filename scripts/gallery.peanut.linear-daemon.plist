<?xml version="1.0" encoding="UTF-8"?>
<!--
  Launchd template for the Linear local daemon. Do NOT hand-edit the
  installed copy in ~/Library/LaunchAgents/ — re-run scripts/install-linear-daemon.sh
  to regenerate it. Three placeholders are substituted by the installer:
    {{TSX_PATH}}     — absolute path to the `tsx` binary (prefers PATH,
                       falls back to $PROJECT_ROOT/node_modules/.bin/tsx)
    {{PROJECT_ROOT}} — absolute path to chrome-extension/
    {{EXTRA_PATH}}   — dirname of the resolved `claude` CLI (usually
                       $HOME/.local/bin) — prepended to PATH below so
                       the daemon's `child_process.spawn('claude', ...)`
                       can find it without hard-coding locations.

  Secrets (LINEAR_API_KEY, CLAUDE_CODE_OAUTH_TOKEN) are NOT in this
  plist. The daemon loads them from ~/.config/peanut-gallery/daemon.env
  at startup (mode 600). Keeps the secrets off the filesystem outside
  that single file.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>gallery.peanut.linear-daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{TSX_PATH}}</string>
    <string>{{PROJECT_ROOT}}/scripts/linear-daemon.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string>{{PROJECT_ROOT}}</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>{{EXTRA_PATH}}:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>{{PROJECT_ROOT}}/logs/daemon-stdout.log</string>

  <key>StandardErrorPath</key>
  <string>{{PROJECT_ROOT}}/logs/daemon-stderr.log</string>
</dict>
</plist>
