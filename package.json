{
  "name": "peanut-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "Your podcast's AI writers' room — 4 AI personas react to live shows in real-time",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:extension": "node --check extension/background.js && node --check extension/offscreen.js && node --check extension/sidepanel.js && node --check extension/content.js",
    "test:transcription": "tsx scripts/test-transcription.ts",
    "test:personas": "tsx scripts/test-personas.ts",
    "test:director": "tsx scripts/test-director.ts",
    "check": "npm run typecheck && npm run check:extension && npm run test:director",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "bufferutil": "^4.1.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
