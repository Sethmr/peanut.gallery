    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
