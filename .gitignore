# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# release artifacts (built by scripts/pack-extension.sh)
/releases/

# debug
/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# commit message scratch (used when committing multi-line messages via -F)
.commit-msg.txt

# local smoke / scratch harnesses (never meant to ship)
scratch-*.ts
scratch-*.js

# Claude worktrees — ephemeral per-ticket working copies spawned by the
# Linear local daemon (scripts/linear-daemon.ts), plus preserved release/*
# worktrees Seth cuts locally. Git auto-manages these via `git worktree add`;
# they should never appear in commits. Earlier `wip: auto-commit` passes
# accidentally tracked release worktrees as gitlinks — this ignore prevents
# recurrence.
.claude/worktrees/

# Persona-research raw audio and whisper model caches. Transcripts live
# in docs/persona-research/transcripts/ and ARE committed; audio files
# and whisper.cpp / openai-whisper models are ephemeral downloads that
# shouldn't touch git. See docs/PERSONA-DATA-ACQUISITION-GUIDE.md.
docs/persona-research/raw-audio/
docs/persona-research/*.m4a
docs/persona-research/*.mp3
docs/persona-research/*.wav
docs/persona-research/*.bin
docs/persona-research/**/_vtt/
