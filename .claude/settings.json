{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push * main:*)",
      "Bash(git push origin main:*)",
      "Bash(git push * master:*)",
      "Bash(git push origin master:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --source *)",
      "Bash(git branch -D main:*)",
      "Bash(git branch -D master:*)",
      "Bash(git branch -D develop:*)",
      "Bash(git tag -d *)",
      "Bash(git push origin --delete *)",
      "Bash(git push origin :refs/heads/*)",

      "Bash(gh pr merge * --base main*)",
      "Bash(gh pr merge * -B main*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh api -X DELETE*)",
      "Bash(gh api --method DELETE*)",
      "Bash(gh auth logout:*)",
      "Bash(gh secret remove:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh variable remove:*)",
      "Bash(gh variable delete:*)",

      "Bash(rm -rf .git:*)",
      "Bash(rm -rf /:*)"
    ],
    "ask": [
      "Bash(gh pr merge:*)",
      "Bash(git tag:*)",
      "Bash(npm publish:*)",
      "Bash(gh release create:*)"
    ]
  }
}
