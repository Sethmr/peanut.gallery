# Peanut Gallery — API Keys
# Copy this to .env.local and fill in your keys

# Deepgram (real-time transcription)
# Get yours: https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

# Anthropic (Claude Haiku for Producer + Joker)
# Get yours: https://console.anthropic.com
ANTHROPIC_API_KEY=

# xAI (Grok 4.1 Fast for Troll + Sound FX, optional Live Search)
# Get yours: https://console.x.ai
XAI_API_KEY=

# Brave Search (real-time fact-checking for Producer)
# Get yours: https://brave.com/search/api/
# Only needed if SEARCH_ENGINE=brave (the default). Skip it if you're
# routing search through xAI Live Search instead.
BRAVE_SEARCH_API_KEY=

# Which search engine backs the Producer's fact-check calls.
#   brave = Brave Search REST API (default, separate BRAVE_SEARCH_API_KEY)
#   xai   = xAI Live Search (reuses XAI_API_KEY, no extra signup)
# The Chrome extension also lets end-users override this per-install.
SEARCH_ENGINE=brave

# yt-dlp cookie browser (optional — fixes "yt-dlp not producing audio")
# YouTube increasingly requires authentication for audio extraction.
# Set to your browser name: chrome, firefox, safari, edge, brave
# Example: YT_DLP_COOKIE_BROWSER=chrome
YT_DLP_COOKIE_BROWSER=

# ── Free-tier rate limiting (hosted backend only) ──
# Turn this on ONLY if you're running a public hosted backend that's paying
# for shared demo keys and want to cap per-install usage. Self-hosters and
# local dev should leave it unset — the limiter is a no-op when this is
# anything other than "true".
# ENABLE_FREE_TIER_LIMIT=true

# Minutes of transcription per rolling window per installation (default: 15).
# Once an install exhausts this, /api/transcribe POST returns 402 and the
# side panel prompts the user to paste their own keys.
# FREE_TIER_MINUTES=15

# Window length, in hours, for the rolling quota (default: 24).
# FREE_TIER_WINDOW_HOURS=24

# ── Smart Director (hosted backend only) ──
# These flags enable the LLM-based routing layer on top of the rule-based
# Director. All are off by default — safe to leave unset in local dev.
#
# v1 / v2 Smart Director — 4-slot free-text JSON router (Haiku).
# Enables director_v2_compare telemetry events.
# ENABLE_SMART_DIRECTOR=true
#
# v3 Smart Director — 5-slot tool_use router with SILENT slot, confidence
# vector, sticky penalty, and callback memory (Haiku). Supersedes v2 when
# both flags are set. Enables director_v3_compare telemetry events.
# SET-14: set this to true on the hosted Railway backend for the 48-hour canary.
# ENABLE_SMART_DIRECTOR_V2=true
#
# Cerebras shadow router — Llama 3.1 8B, fires in parallel with v2/v3 Haiku
# and logs director_shadow_compare events. Requires CEREBRAS_API_KEY.
# ENABLE_SMART_DIRECTOR_V3_CEREBRAS=true
# CEREBRAS_API_KEY=
#
# Groq shadow router — same model as Cerebras; deferred pending Developer tier.
# Requires GROQ_API_KEY. See Linear SET-11.
# ENABLE_SMART_DIRECTOR_V3_GROQ=true
# GROQ_API_KEY=
