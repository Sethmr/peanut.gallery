# Peanut Gallery — API Keys
# Copy this to .env.local and fill in your keys

# Deepgram (real-time transcription)
# Get yours: https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

# Anthropic (Claude Haiku for Producer + Joker)
# Get yours: https://console.anthropic.com
ANTHROPIC_API_KEY=

# xAI (Grok 4.1 Fast for Troll + Sound FX, optional Live Search)
# Get yours: https://console.x.ai
XAI_API_KEY=

# Brave Search (real-time fact-checking for Producer)
# Get yours: https://brave.com/search/api/
# Only needed if SEARCH_ENGINE=brave (the default). Skip it if you're
# routing search through xAI Live Search instead.
BRAVE_SEARCH_API_KEY=

# Which search engine backs the Producer's fact-check calls.
#   brave = Brave Search REST API (default, separate BRAVE_SEARCH_API_KEY)
#   xai   = xAI Live Search (reuses XAI_API_KEY, no extra signup)
# The Chrome extension also lets end-users override this per-install.
SEARCH_ENGINE=brave

# yt-dlp cookie browser (optional — fixes "yt-dlp not producing audio")
# YouTube increasingly requires authentication for audio extraction.
# Set to your browser name: chrome, firefox, safari, edge, brave
# Example: YT_DLP_COOKIE_BROWSER=chrome
YT_DLP_COOKIE_BROWSER=

# ── Free-tier rate limiting (hosted backend only) ──
# Turn this on ONLY if you're running a public hosted backend that's paying
# for shared demo keys and want to cap per-install usage. Self-hosters and
# local dev should leave it unset — the limiter is a no-op when this is
# anything other than "true".
# ENABLE_FREE_TIER_LIMIT=true

# Minutes of transcription per rolling window per installation (default: 15).
# Once an install exhausts this, /api/transcribe POST returns 402 and the
# side panel prompts the user to paste their own keys.
# FREE_TIER_MINUTES=15

# Window length, in hours, for the rolling quota (default: 24).
# FREE_TIER_WINDOW_HOURS=24

# ── Smart Director (hosted backend only) ──
# These flags enable the LLM-based routing layer on top of the rule-based
# Director. All are off by default — safe to leave unset in local dev.
#
# v1 / v2 Smart Director — 4-slot free-text JSON router (Haiku).
# Enables director_v2_compare telemetry events.
# ENABLE_SMART_DIRECTOR=true
#
# v3 Smart Director — 5-slot tool_use router with SILENT slot, confidence
# vector, sticky penalty, and callback memory (Haiku). Supersedes v2 when
# both flags are set. Enables director_v3_compare telemetry events.
# SET-14: set this to true on the hosted Railway backend for the 48-hour canary.
# ENABLE_SMART_DIRECTOR_V2=true
#
# Cerebras shadow router — Llama 3.1 8B with the v3 prompt (5-slot +
# confidence + json_schema), fires in parallel with v2/v3 Haiku and logs
# director_v3_shadow_compare events. Requires CEREBRAS_API_KEY.
# ENABLE_SMART_DIRECTOR_V3_CEREBRAS_V3PROMPT=true
# CEREBRAS_API_KEY=
#
# Groq shadow router — same model + prompt as Cerebras; deferred pending
# Developer tier reopening. Requires GROQ_API_KEY. See Linear SET-11.
# ENABLE_SMART_DIRECTOR_V3_GROQ_V3PROMPT=true
# GROQ_API_KEY=

# ── Peanut Gallery Plus — transactional email (Phase 4) ──
# Wire when ENABLE_SUBSCRIPTION=true and you want welcome / recovery /
# cancellation emails to actually go out. Required for SET-27 acceptance.
#
# Provider: "resend" (default) or "postmark". Same wire shape on our side;
# pick whichever matches the API key you have. Resend free tier covers
# 3k emails/month — fine for the early subscriber stage.
#   EMAIL_PROVIDER=resend
#
# Provider API key. For Resend get yours at https://resend.com/api-keys.
# For Postmark get yours at https://account.postmarkapp.com/servers (use
# the Server API token, not the Account token).
#   EMAIL_API_KEY=
#
# `From` address on outbound transactional mail. Must be a verified
# sender on whichever provider you're using (DNS records: SPF, DKIM,
# DMARC). Defaults to subscriptions@peanutgallery.live.
#   EMAIL_FROM=subscriptions@peanutgallery.live
#
# `Reply-To` address. Goes to whichever inbox you check when a user
# hits Reply on a Plus email. Defaults to support@peanutgallery.live.
#   EMAIL_REPLY_TO=support@peanutgallery.live
#
# Self-host opt-out — short-circuits all email sends with a log line
# and returns ok:true,skipped:true to the caller. Use this if you're
# running Plus internally without SMTP plumbing; keys can be hand-
# delivered by reading the subscription_email_skipped log events.
#   DISABLE_EMAIL_SEND=true
#
# Stripe Customer Portal URL — pre-signed by Stripe and consumed by
# /api/subscription/manage when the user picks "cancel" / "billing".
# Optional; when unset, those actions fall back to a "we'll reach
# out manually" response so the request isn't silently dropped.
#   STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...

# ── Peanut Gallery Plus — persistent subscription identity (SET-25 / Phase 2) ──
# When set, lib/subscription.ts delegates to a SQLite database instead of
# the in-memory env-whitelist store. License keys + weekly usage counters
# survive Railway redeploys, which is required for the Privacy Policy's
# encryption-at-rest promise and for a credible Phase 3 Stripe rollout.
#
# Unset → Phase 1 behavior preserved exactly (in-memory + SUBSCRIPTION_KEYS_WHITELIST).
# Set   → Phase 2 durable storage at the given file path.
#
# The file is created on first boot if it doesn't exist; the directory
# must be writable. On Railway, point this at a mounted volume.
#   SUBSCRIPTION_DB_PATH=/data/subscriptions.db
#
# Optional SQLCipher key — if the better-sqlite3 binary your runtime
# ships supports SQLCipher (the npm default doesn't), setting this
# encrypts the database at rest with the provided passphrase. When
# unset or when the binary is vanilla, the module falls back to
# filesystem-level encryption and logs subscription_db_disk_encryption_only.
#   SUBSCRIPTION_DB_KEY=
#
# ── Admin CLI for Phase 2 key issuance (SET-25) ──
# When ENABLE_SUBSCRIPTION=true + SUBSCRIPTION_DB_PATH is set, you can
# hand-issue license keys via:
#   npm run subscription:issue -- --email alice@example.com
#   npm run subscription:issue -- --email alice@example.com --stripe-sub sub_xxx
# Dry-run the generator without touching the store:
#   npm run subscription:issue -- --email test@example.com --dry-run
# See scripts/subscription-issue.ts for the full interface.
