{
  "manifest_version": 3,
  "name": "Peanut Gallery",
  "version": "1.7.0",
  "description": "AI writers' room for YouTube. 4 personas react live — fact-checker, troll, sound guy, comedy writer. Howard or TWiST pack.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://peanutgallery.live/*",
    "https://api.peanutgallery.live/*",
    "https://www.peanutgallery.live/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Peanut Gallery — click to capture this tab's audio",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://peanutgallery.live/*", "https://www.peanutgallery.live/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
