{
  "manifest_version": 3,
  "name": "Peanut Gallery",
  "version": "1.0.3",
  "description": "Watch any YouTube video with an AI writers' room. 4 personas react in real-time in a native Chrome side panel.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://peanutgallery.live/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Peanut Gallery — click to capture this tab's audio",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://peanutgallery.live/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
