{
  "manifest_version": 3,
  "name": "Peanut Gallery",
  "version": "1.0.0",
  "description": "AI podcast sidebar — captures tab audio and streams it to Peanut Gallery for real-time commentary.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "http://localhost:*/*",
    "https://*.peanut.gallery/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "https://*.peanut.gallery/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
